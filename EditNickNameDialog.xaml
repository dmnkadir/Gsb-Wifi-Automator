<Window x:Class="GsbWifiOtomasyon.EditNicknameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="İsim Düzenle" Height="200" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="15" Background="#F6EBD5" BorderBrush="#3E2723" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#3E2723" CornerRadius="13,13,0,0">
                <TextBlock Text="İsim Düzenle" Foreground="#F6EBD5" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="20">
                <TextBlock x:Name="lblInstruction" Text="Yeni hesap ismini girin:" Foreground="#3E2723" Margin="0,0,0,10" FontWeight="SemiBold"/>
                <TextBox x:Name="txtNickname" Height="35" VerticalContentAlignment="Center" Padding="5" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="KAYDET" Grid.Column="0" Margin="0,0,5,0" Height="35" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="btnSave_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="İPTAL" Grid.Column="1" Margin="5,0,0,0" Height="35" Background="#9E9E9E" Foreground="White" FontWeight="Bold" Click="btnCancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>