<Window x:Class="GsbWifiOtomasyon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GsbWifiOtomasyon"
        mc:Ignorable="d"
        Title="GSB Wifi Kontrol Pro" Height="580" Width="800" 
        ResizeMode="NoResize" WindowStyle="None"
        WindowStartupLocation="CenterScreen" 
        Background="Transparent" 
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="RenkliButonStili" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" BorderThickness="0">
                            <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3E2723"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="VurguluYazi" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5D4037"/>
        </Style>

        <Style x:Key="DonateButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter x:Name="content" RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="content" 
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                 To="1.15" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="content" 
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                 To="1.15" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="content" 
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                 To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="content" 
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                 To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border CornerRadius="4" Background="#A1887F" Opacity="0.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="20" Background="#F6EBD5" ClipToBounds="True" BorderBrush="#3E2723" BorderThickness="1">
        <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

            <Border x:Name="CustomTitleBar" 
        Grid.ColumnSpan="2" 
        VerticalAlignment="Top" 
        Height="30" 
        Background="#3E2723" 
        CornerRadius="20,20,0,0" 
        MouseDown="CustomTitleBar_MouseDown">
                <Grid>
                <TextBlock Text="GSB Wifi Kontrol Pro" 
                   Foreground="#F6EBD5" 
                   VerticalAlignment="Center" 
                   Margin="15,0,0,0" 
                   FontSize="12"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel.Resources>
                        <Style x:Key="WinBtnStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="#F6EBD5"/>
                            <Setter Property="FontFamily" Value="Marlett"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Width" Value="46"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5A423C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                            <Style x:Key="WinCloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,20,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E81123"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>

                    <Button x:Name="btnMinimize" Content="0" Style="{StaticResource WinBtnStyle}" Click="btnMinimize_Click"/>
                    <Button x:Name="btnClose" Content="r" Style="{StaticResource WinCloseBtnStyle}" Click="btnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="0" Padding="20" BorderBrush="#D1D5DB" BorderThickness="0,0,1,0" Margin="0,30,0,0">
            <StackPanel>
                    <Border Background="#5D4037" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="GSB Wi-Fi" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Otomasyon Paneli" Foreground="#D7CCC8" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="panelLogin">
                    <TextBlock Text="Kullanıcı Adı" FontWeight="SemiBold" Margin="0,5"/>
                    <TextBox x:Name="txtUsername" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                    <TextBlock Text="Şifre" FontWeight="SemiBold" Margin="0,10,0,5"/>
                        <Grid Margin="0,0,0,5">
                            <PasswordBox x:Name="txtPassword" Height="35" VerticalContentAlignment="Center" Padding="5,5,35,5"/>

                            <TextBox x:Name="txtVisiblePassword" Height="35" VerticalContentAlignment="Center" Padding="5,5,35,5" Visibility="Collapsed" Background="White"/>

                            <Button x:Name="btnShowPassword" 
                                Content="&#xE7B3;" 
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Style="{StaticResource EyeButtonStyle}" 
                                HorizontalAlignment="Right" VerticalAlignment="Center" 
                                Width="30" Height="30" Margin="0,0,5,0" 
                                Cursor="Hand" Click="btnShowPassword_Click"/>
                        </Grid>
                        <Button x:Name="btnLogin" 
                            Content="GİRİŞ YAP" 
                            Height="45" 
                            Margin="0,15,0,0" 
                            Background="#5D4037" 
                            Style="{StaticResource RenkliButonStili}" 
                            Click="btnLogin_Click"/>
                        <CheckBox x:Name="chkSaveAccount" Content="Giriş Başarılı Olursa Hesabı Kaydet" Margin="0,10,0,0" FontWeight="SemiBold"/>

                    <Grid x:Name="panelSaveNickname" Visibility="Collapsed" Margin="0,10,0,0">
                        <Border Background="#E3F2FD" CornerRadius="10" Padding="15" BorderBrush="#D2B48C" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Hesabı Kaydet" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,5"/>
                                <TextBlock Text="Bu hesaba bir isim verin (İsteğe bağlı):" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtNewNickname" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="KAYDET" Grid.Column="0" Background="#4CAF50" Foreground="White" FontWeight="Bold" Height="30" Margin="0,0,5,0" Click="btnConfirmSave_Click"/>
                                    <Button Content="İPTAL" Grid.Column="1" Background="#9E9E9E" Foreground="White" Height="30" Click="btnCancelSave_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                    <StackPanel x:Name="panelControls" Visibility="Collapsed" Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="30"/>
                        </StackPanel.RenderTransform>
                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="KALAN KOTA" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="txtQuota" Text="Yükleniyor..." Style="{StaticResource VurguluYazi}" Margin="0,5,0,0" TextAlignment="Center"/>
                            <Button Content="Yenile" HorizontalAlignment="Right" FontSize="10" Background="Transparent" BorderThickness="0" Foreground="#007ACC" Click="btnQuotaRefresh_Click"/>
                        </StackPanel>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnStart" Grid.Column="0" Content="BAŞLAT" Height="80" Background="#4CAF50" Style="{StaticResource RenkliButonStili}" Click="btnStart_Click"/>
                        <Button x:Name="btnStop" Grid.Column="2" Content="DURDUR" Height="80" Background="#F44336" Style="{StaticResource RenkliButonStili}" Click="btnStop_Click"/>
                    </Grid>

                    <Button x:Name="btnExitSession" Content="OTURUMDAN ÇIKIŞ YAP" Height="45" Margin="0,15,0,0"  Background="#78909C"  Style="{StaticResource RenkliButonStili}"  Click="btnExitSession_Click"/>
                </StackPanel>
                <TextBlock x:Name="txtStatus" Text="Hazır..." Margin="0,20,0,0" Foreground="#8D6E63" FontSize="11" FontStyle="Italic" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

            <Border Grid.Column="1" Padding="20" Margin="0,30,0,0" CornerRadius="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="KAYITLI HESAPLAR" FontWeight="Bold" FontSize="16" Foreground="#374151" Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,105">
                        <ItemsControl x:Name="listSavedAccounts">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Margin="0,0,10,10" Padding="10" BorderBrush="#E5E7EB" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nickname}" FontWeight="Bold" FontSize="14" Foreground="#111827"/>
                                                <TextBlock Text="{Binding Username}" FontSize="11" Foreground="#6B7280"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="GİRİŞ" Width="55" Height="35" Background="#4CAF50" 
                                            Style="{StaticResource RenkliButonStili}" 
                                            Margin="0,0,5,0" Click="btnQuickLogin_Click" Tag="{Binding}"/>

                                                <Button Content="⚙️" Width="35" Height="35" Background="#FFB300" 
                                            Style="{StaticResource RenkliButonStili}" 
                                            Margin="0,0,5,0" Click="btnEditNickname_Click" Tag="{Binding}" ToolTip="İsmi Düzenle"/>

                                                <Button Content="SİL" Width="35" Height="35" Background="#F44336" 
                                            Style="{StaticResource RenkliButonStili}" 
                                            FontSize="10" Click="btnDeleteAccount_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Button x:Name="btnDonate"
        Grid.ColumnSpan="2" 
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,15,15"
        Width="90" Height="90" 
        Style="{StaticResource DonateButtonStyle}"
        Cursor="Hand"
        Click="btnDonate_Click"
        ToolTip="Projeye Destek Ol">
                <Image Source="/Assets/BuyMeACoffe.png" 
           Stretch="Uniform"
           RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
        </Grid>
    </Border>
</Window>